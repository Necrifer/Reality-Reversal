// Sample Modular Machinery Reborn environmental decontaminator.
//
// Nuclear Radiation 1.0.2 does not expose a supported KubeJS cleanup API.
// This integration uses its public Java methods directly; see the matching
// warning JSON in config/codex_warnings before updating Nuclear Radiation.

const NR_DECONTAMINATOR_MACHINE = 'modpack:environmental_decontaminator'
const NR_DECONTAMINATOR_FUNCTION = 'modpack:clear_nuclear_radiation_chunk'

MMREvents.machines(event => {
  event.create(NR_DECONTAMINATOR_MACHINE)
    .name('Environmental Decontaminator')
    .color(0x55ffaa)
    .structure(
      MMRStructureBuilder.create()
        .pattern([
          [
            'CCC',
            'CEC',
            'CCC'
          ],
          [
            'CCC',
            'CmC',
            'CCC'
          ]
        ])
        .keys({
          'm': 'modular_machinery_reborn:controller',
          C: 'modular_machinery_reborn:casing_reinforced',
          E: 'modular_machinery_reborn:energyinputhatch_normal'
        })
    )
})

ServerEvents.recipes(event => {
  // 600 ticks at 4,096 FE/t = 2,457,600 FE per cleaned chunk.
  event.recipes.modular_machinery_reborn
    .machine_recipe(NR_DECONTAMINATOR_MACHINE, 600)
    .requireEnergyPerTick(4096)
    .requireFunctionOnEnd(NR_DECONTAMINATOR_FUNCTION)
    .id('modpack:environmental_decontamination')
})

MMREvents.recipeFunction(NR_DECONTAMINATOR_FUNCTION, event => {
  const WorldSourceRegistry = Java.loadClass(
    'igentuman.nr.util.tracking.WorldSourceRegistry'
  )
  const RadiationProfile = Java.loadClass(
    'igentuman.nr.api.RadiationProfile'
  )
  const ChunkPos = Java.loadClass(
    'net.minecraft.world.level.ChunkPos'
  )

  const level = event.tile.level
  const controllerPos = event.tile.blockPos
  const controllerChunk = new ChunkPos(controllerPos)
  const registry = WorldSourceRegistry.get(level)

  // Use separate empty profiles because these objects are mutable.
  // Passing a real ChunkPos is required: passing BlockPos makes Rhino treat
  // Nuclear Radiation's BlockPos and ChunkPos overloads as ambiguous.
  registry.setChunkRadiation(
    controllerChunk,
    RadiationProfile.empty(),
    RadiationProfile.empty(),
    RadiationProfile.empty()
  )

  console.info(
    `[Environmental Decontaminator] Cleared Nuclear Radiation contamination ` +
    `in chunk (${controllerChunk.x}, ${controllerChunk.z}) of ${level.dimension().location()}`
  )

  // Active radioactive blocks, fluids, containers, and dropped items remain
  // real sources and can contaminate this chunk again after the recipe ends.
})
