StartupEvents.registry('item', event => {
  CUSTOM_INGOT_PART_MATERIALS.forEach(material => {
    CUSTOM_INGOT_PART_TYPES.forEach(part => {
      event.create(`${material.id}_${part.id}`)
        .displayName(`${material.name} ${part.name}`)
        .color(0, material.color)
        .tag(`c:${part.tag}`)
        .tag(`c:${part.tag}/${material.id}`);
    });
  });
});
